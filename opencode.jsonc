{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server on host",
      "options": {
        "baseURL": "http://host.docker.internal:1234/v1"
      },
      "models": {
        "Qwen3.6-35B-A3B": {
          "name": "Qwen3.6-35B-A3B via local llama-server",
          "limit": {
            "context": 176608,
            "output": 32768
          }
        },
        "Qwen3.6-27B": {
          "name": "Qwen3.6-27B via local llama-server",
          "limit": {
            "context": 176608,
            "output": 32768
          }
        }
      }
    }
  },
  "model": "llama.cpp-local/Qwen3.6-35B-A3B",
  "small_model": "llama.cpp-local/Qwen3.6-35B-A3B",
  "mcp": {
    "aws-mcp": {
      "type": "local",
      "enabled": true,
      "command": [
        "bash",
        "agent/scripts/aws-mcp-wrapper.sh"
      ],
      "timeout": 100000
    }
  },
  "permission": {
    "*": "allow",
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      ".env": "ask",
      "*/.env": "ask",
      "*/.env.*": "ask",
      "*.env.example": "allow",
      "*/.env.example": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "question": "allow",
    "edit": "allow",
    "lsp": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "aws-mcp_*": "allow",
    "aws___*": "allow",
    "aws_*": "allow",
    "bash": {
      "*": "allow",
      "sudo": "ask",
      "sudo *": "ask",
      "rm -rf": "ask",
      "rm -rf*": "ask",
      "chmod -R": "ask",
      "chmod -R*": "ask",
      "chown -R": "ask",
      "chown -R*": "ask",
      "git commit": "ask",
      "git commit*": "ask",
      "git push": "ask",
      "git push*": "ask",
      "cat *.env*": "ask",
      "cat */.env*": "ask",
      "less *.env*": "ask",
      "less */.env*": "ask",
      "printenv": "ask",
      "printenv*": "ask",
      "env": "ask"
    },
    "external_directory": "ask",
    "doom_loop": "ask"
  }
}
