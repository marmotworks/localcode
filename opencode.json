{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "formatter": true,
  "lsp": true,
  "model": "North-Mini-Code",
  "permission": {
    "question": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "lsp": "allow"
  },
  "tools": {
    "websearch": true,
    "codesearch": true
  },
  "share": "disabled",
  "enabled_providers": ["llama.cpp"],
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8001/v1"
      },
      "models": {
        "gemma-4-31b-it-qat": {
          "name": "gemma-4-31b-it-qat",
          "limit": {
            "context": 176608,
            "output": 32768
          }
        },
        "North-Mini-Code": {
          "name": "North-Mini-Code",
          "limit": {
            "context": 256000,
            "output": 64000
          }
        },
        "gemma-4-26b-a4b-it": {
          "name": "gemma-4-26b-a4b-it",
          "limit": {
            "context": 176608,
            "output": 32768
          }
        },
        "Qwen3.6-35B-A3B": {
          "name": "Qwen3.6-35B-A3B",
          "limit": {
            "context": 262144,
            "output": 32768
          }
        },
        "Qwen3.6-27B-MTP": {
          "name": "Qwen3.6-27B-MTP",
          "limit": {
            "context": 176608,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "aws-mcp": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-proxy-for-aws==1.6.0",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata", "AWS_REGION=us-east-1"
      ]
    }
  }
}