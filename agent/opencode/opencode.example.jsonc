{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "options": {
        "baseURL": "http://host.docker.internal:1234/v1"
      }
    }
  },
  "model": "llama.cpp/Qwen3.6-35B-A3B",
  "small_model": "llama.cpp/Qwen3.6-35B-A3B",
  "mcp": {
    "aws-mcp": {
      "type": "local",
      "enabled": true,
      "command": [
        "bash",
        "agent/scripts/aws-mcp-wrapper.sh"
      ],
      "timeout": 100000
    }
  },
  "permission": {
    "*": "allow",
    "read": {
      "*": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "question": "allow",
    "edit": "allow",
    "lsp": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "aws-mcp_*": "allow",
    "aws___*": "allow",
    "aws_*": "allow",
    "bash": {
      "*": "allow"
    },
    "external_directory": "allow",
    "doom_loop": "allow"
  }
}
